# 1. GEOAPIFY API (Untuk Pencarian Spot Foto)
# Daftar di: myprojects.geoapify.com
GEOAPIFY_API_KEY=masukkan_key_geoapify_kamu_disini

# 2. GOOGLE GEMINI API (Untuk AI Caption/Hashtag)
